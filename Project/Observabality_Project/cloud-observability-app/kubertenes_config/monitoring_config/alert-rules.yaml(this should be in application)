# alert-rules.yaml
apiVersion: monitoring.coreos.com/v1
kind: PrometheusRule
metadata:
  name: app-alert-rules
  namespace: app
  labels:
    release: monitoring       # must match your helm release name
spec:
  groups:
    - name: app.rules
      rules:

        # Alert 1 — High Error Rate
        - alert: HighErrorRate
          expr: rate(app_errors_total[20s]) > 0.01
          for: 1m
          labels:
            severity: critical
          annotations:
            summary: "High error rate detected"
            description: "Error rate is {{ $value }} errors/sec on {{ $labels.endpoint }}"

        # Alert 2 — High Latency
        - alert: HighLatency
          expr: histogram_quantile(0.95, rate(app_request_latency_seconds_bucket[5m])) > 1.0
          for: 2m
          labels:
            severity: warning
          annotations:
            summary: "High p95 latency detected"
            description: "p95 latency is {{ $value }}s on {{ $labels.endpoint }}"

        # Alert 3 — App Down
        - alert: AppDown
          expr: up{job="observability-demo-app"} == 0
          for: 1m
          labels:
            severity: critical
          annotations:
            summary: "App is down"
            description: "observability-demo-app has been down for more than 1 minute"